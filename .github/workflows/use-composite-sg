jobs:
  security-gate:
    runs-on: ubuntu-latest
    steps:
      # Step A: Pull your private code into their runner
      - name: Checkout Security Gate Action
        uses: actions/checkout@v4
        with:
          repository: pagopa/prodsec-security-gates
          ref: main # or a specific commit hash
          token: ${{ secrets.YOUR_ORG_READ_TOKEN }} # Required for public -> private access
          path: ./.github/actions/security-gate

      # Step B: Run the code locally
      - name: Run Security Gate
        uses: ./.github/actions/security-gate
        with:
          force_release: ${{ inputs.bypass_security_checks_manual == true || vars.BYPASS_SECURITY_CHECKS == 'true' }}
